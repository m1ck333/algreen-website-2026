---
import { useTranslations } from '../../i18n/ui';
import { company, type Lang } from '../../i18n/config';
import PageHero from '../PageHero.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const txt = (v: string | Record<Lang, string>) => (typeof v === 'string' ? v : v[lang]);
---

<PageHero title={t.contact.title} subtitle={t.contact.subtitle} eyebrow={t.nav.contact} image="/img/kontakt.jpg" />

<section class="section">
  <div class="container-px grid gap-12 lg:grid-cols-[1fr_1.1fr]">
    <!-- Branch cards -->
    <div class="space-y-6">
      {
        company.branches.map((b) => (
          <div class="rounded-2xl bg-white p-7 shadow-sm ring-1 ring-ink-900/5 reveal">
            <h2 class="text-xl font-semibold text-ink-900">
              {t.contact.branchOffice} {txt(b.city)}
            </h2>
            <dl class="mt-5 space-y-4 text-sm">
              <div class="flex gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21s-7-5.5-7-11a7 7 0 1114 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
                <div>
                  <dt class="font-medium text-ink-900">{t.contact.address}</dt>
                  <dd class="text-ink-700">{txt(b.street)}, {txt(b.postal)}</dd>
                  <a href={b.mapsUrl} target="_blank" rel="noopener" class="mt-1 inline-block text-xs font-semibold text-gold-dark hover:underline">{t.contact.openMaps} →</a>
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.3a1 1 0 011 .76l1 4a1 1 0 01-.3 1L8 10.5a14 14 0 005.5 5.5l1.7-1.3a1 1 0 011-.2l4 1a1 1 0 01.8 1V19a2 2 0 01-2 2A16 16 0 013 5z"/></svg>
                <div>
                  <dt class="font-medium text-ink-900">{t.contact.phone}</dt>
                  {b.phones.map((p) => (
                    <dd><a href={`tel:${p.replace(/[^+\d]/g, '')}`} class="text-ink-700 hover:text-gold-dark">{p}</a></dd>
                  ))}
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7l9 6 9-6M4 5h16a1 1 0 011 1v12a1 1 0 01-1 1H4a1 1 0 01-1-1V6a1 1 0 011-1z"/></svg>
                <div>
                  <dt class="font-medium text-ink-900">{t.contact.email}</dt>
                  <dd><a href={`mailto:${b.email}`} class="text-ink-700 hover:text-gold-dark">{b.email}</a></dd>
                </div>
              </div>
            </dl>
          </div>
        ))
      }
    </div>

    <!-- Inquiry form -->
    <div class="rounded-2xl bg-ink-900 p-8 text-white reveal">
      <h2 class="text-2xl font-semibold">{t.contact.formHeading}</h2>
      <p class="mt-2 text-sm text-white/60">{t.contact.formNote}</p>
      <form
        class="mt-6 space-y-4"
        action={`mailto:${company.branches[0].email}`}
        method="post"
        enctype="text/plain"
      >
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="mb-1.5 block text-sm text-white/70">{t.contact.formName}</span>
            <input type="text" name="name" required class="w-full rounded-lg border border-white/15 bg-white/5 px-4 py-3 text-white placeholder-white/30 focus:border-gold focus:outline-none" />
          </label>
          <label class="block">
            <span class="mb-1.5 block text-sm text-white/70">{t.contact.formPhone}</span>
            <input type="tel" name="phone" class="w-full rounded-lg border border-white/15 bg-white/5 px-4 py-3 text-white placeholder-white/30 focus:border-gold focus:outline-none" />
          </label>
        </div>
        <label class="block">
          <span class="mb-1.5 block text-sm text-white/70">{t.contact.formEmail}</span>
          <input type="email" name="email" required class="w-full rounded-lg border border-white/15 bg-white/5 px-4 py-3 text-white placeholder-white/30 focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="mb-1.5 block text-sm text-white/70">{t.contact.formMessage}</span>
          <textarea name="message" rows="5" required class="w-full rounded-lg border border-white/15 bg-white/5 px-4 py-3 text-white placeholder-white/30 focus:border-gold focus:outline-none"></textarea>
        </label>
        <button type="submit" class="btn-primary w-full sm:w-auto">{t.contact.formSubmit}</button>
      </form>
    </div>
  </div>
</section>

<!-- Map -->
<section class="pb-0">
  <iframe
    title="Algreen Niš"
    src="https://www.google.com/maps?q=Bulevar+Svetog+Cara+Konstantina+168,+Niš&output=embed"
    class="h-[420px] w-full border-0 grayscale"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"></iframe>
</section>
