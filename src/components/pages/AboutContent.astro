---
import { useTranslations } from '../../i18n/ui';
import { type Lang } from '../../i18n/config';
import PageHero from '../PageHero.astro';
import CtaBand from '../CtaBand.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const stepImages = ['/img/about1.png', '/img/about2.png', '/img/about3.png', '/img/about4.png'];
const teamImages = ['/img/tim1.png', '/img/tim2.png', '/img/tim3.png', '/img/tim4.png', '/img/tim5.png', '/img/tim6.png'];
const teamEyebrow = lang === 'sr' ? 'Tim' : 'Team';
---

<PageHero title={t.about.title} subtitle={t.about.subtitle} eyebrow={t.nav.about} image="/img/onama.jpg" />

<!-- Process steps -->
<section class="section">
  <div class="container-px">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        t.about.steps.map((step, i) => (
          <div class="group relative overflow-hidden rounded-2xl reveal">
            <img src={stepImages[i]} alt={step} loading="lazy" class="aspect-square w-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-900/80 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-5">
              <span class="text-sm font-semibold text-gold">0{i + 1}</span>
              <h3 class="text-xl font-semibold text-white">{step}</h3>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Main statement -->
<section class="bg-brand-50 section">
  <div class="container-px max-w-4xl text-center reveal">
    <h2 class="text-3xl font-semibold text-ink-900 sm:text-4xl">{t.about.mainHeading}</h2>
    <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-ink-700">{t.about.mainText}</p>
  </div>
</section>

<!-- Team -->
<section class="section">
  <div class="container-px">
    <div class="mx-auto mb-14 max-w-2xl text-center reveal">
      <p class="eyebrow">{teamEyebrow}</p>
      <h2 class="text-3xl font-semibold text-ink-900 sm:text-4xl">{t.about.teamHeading}</h2>
    </div>
    <div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3">
      {
        t.about.team.map((member, i) => (
          <article class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-ink-900/5 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl reveal">
            <div class="aspect-[16/10] overflow-hidden bg-brand-100">
              <img src={teamImages[i]} alt={member.title} loading="lazy" class="h-full w-full object-cover" />
            </div>
            <div class="p-6">
              <h3 class="text-lg font-semibold text-ink-900">{member.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-700">{member.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- Values -->
<section class="section bg-ink-900">
  <div class="container-px">
    <h2 class="mb-12 text-center text-3xl font-semibold text-white sm:text-4xl reveal">{t.about.valuesHeading}</h2>
    <div class="grid gap-8 md:grid-cols-3">
      {
        t.about.values.map((v) => (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-8 reveal">
            <div class="mb-4 h-1 w-12 rounded bg-gold"></div>
            <h3 class="text-2xl font-semibold text-white">{v.title}</h3>
            <p class="mt-4 leading-relaxed text-white/70">{v.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<CtaBand lang={lang} variant="contact" />
