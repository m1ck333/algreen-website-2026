---
import { useTranslations } from '../i18n/ui';
import { path } from '../i18n/routes';
import { company, type Lang } from '../i18n/config';

interface Props {
  lang: Lang;
  variant?: 'configurator' | 'contact';
}
const { lang, variant = 'configurator' } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-ink-900">
  <img
    src="/img/hero-door-new-2.jpg"
    alt=""
    aria-hidden="true"
    loading="lazy"
    class="absolute inset-0 h-full w-full object-cover opacity-20"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-ink-900 via-ink-900/90 to-ink-900/60"></div>
  <div class="container-px relative flex flex-col items-start gap-6 py-16 sm:py-20 md:flex-row md:items-center md:justify-between">
    <div class="max-w-2xl reveal">
      <h2 class="text-3xl font-semibold text-white sm:text-4xl">{t.home.ctaHeading}</h2>
      <p class="mt-3 text-white/70">{t.home.ctaText}</p>
    </div>
    <div class="flex flex-wrap gap-3 reveal">
      {
        variant === 'configurator' ? (
          <a href={company.configurator} class="btn-primary">{t.common.configurator}</a>
        ) : (
          <a href={path('contact', lang)} class="btn-primary">{t.common.contactUs}</a>
        )
      }
      <a href={path('contact', lang)} class="btn-ghost">{t.common.getInTouch}</a>
    </div>
  </div>
</section>
