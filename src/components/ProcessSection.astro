---
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const icons = ['ruler', 'sliders', 'factory', 'truck'];
---

<section class="section">
  <div class="container-px">
    <div class="mx-auto mb-16 max-w-2xl text-center reveal">
      <p class="eyebrow eyebrow-center">{lang === 'sr' ? 'Proces' : 'Process'}</p>
      <h2 class="font-display text-4xl font-semibold text-ink-900 sm:text-5xl">{t.process.heading}</h2>
      <p class="mt-4 text-ink-700">{t.process.subheading}</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {
        t.process.steps.map((step, i) => (
          <div class="relative reveal" data-delay={String(i + 1)}>
            {/* connecting line on desktop */}
            {i < t.process.steps.length - 1 && (
              <div class="absolute left-[3.5rem] top-7 hidden h-px w-[calc(100%-2rem)] bg-gradient-to-r from-gold/50 to-transparent lg:block" />
            )}
            <div class="flex items-center gap-4">
              <div class="relative z-10 flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-ink-900 text-gold">
                {icons[i] === 'ruler' && <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17L17 3l4 4L7 21l-4-4z"/><path stroke-linecap="round" d="M8 8l2 2M11 5l2 2M5 11l2 2"/></svg>}
                {icons[i] === 'sliders' && <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h10M18 6h2M4 12h2M10 12h10M4 18h8M16 18h4"/><circle cx="16" cy="6" r="2"/><circle cx="8" cy="12" r="2"/><circle cx="14" cy="18" r="2"/></svg>}
                {icons[i] === 'factory' && <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21V9l6 4V9l6 4V9l6 4v8H3z"/><path d="M3 21h18"/></svg>}
                {icons[i] === 'truck' && <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7h11v8H3zM14 10h4l3 3v2h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17.5" cy="18" r="1.6"/></svg>}
              </div>
              <span class="font-display text-3xl font-semibold text-gold/40">0{i + 1}</span>
            </div>
            <h3 class="mt-5 font-display text-xl font-semibold text-ink-900">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-700">{step.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
