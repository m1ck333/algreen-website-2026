---
import { useTranslations } from '../i18n/ui';
import { company, type Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const phone = company.branches[0].phones[0];
const tel = phone.replace(/[^+\d]/g, '');
---

<!-- Mobile-only conversion bar: quick call + configurator -->
<div class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 border-t border-white/10 shadow-[0_-8px_24px_-12px_rgba(0,0,0,0.4)] lg:hidden">
  <a
    href={`tel:${tel}`}
    class="flex items-center justify-center gap-2 bg-ink-900 py-3.5 text-sm font-semibold uppercase tracking-wider text-white"
  >
    <svg class="h-4 w-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.9"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.3a1 1 0 011 .76l1 4a1 1 0 01-.3 1L8 10.5a14 14 0 005.5 5.5l1.7-1.3a1 1 0 011-.2l4 1a1 1 0 01.8 1V19a2 2 0 01-2 2A16 16 0 013 5z"/></svg>
    {lang === 'sr' ? 'Pozovite' : 'Call'}
  </a>
  <a
    href={company.configurator}
    class="flex items-center justify-center gap-2 bg-gold py-3.5 text-sm font-semibold uppercase tracking-wider text-ink-900"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.9"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
    {t.common.configurator}
  </a>
</div>
