---
import { useTranslations } from '../i18n/ui';
import { path } from '../i18n/routes';
import type { Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// FAQPage structured data — eligible for rich results in search.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<section class="section bg-cream-50">
  <div class="container-px max-w-3xl">
    <div class="mb-12 text-center reveal">
      <p class="eyebrow eyebrow-center">FAQ</p>
      <h2 class="font-display text-4xl font-semibold text-ink-900 sm:text-5xl">{t.faq.heading}</h2>
      <p class="mt-4 text-ink-700">{t.faq.subheading}</p>
    </div>

    <div class="divide-y divide-ink-900/10 border-y border-ink-900/10">
      {
        t.faq.items.map((item) => (
          <details class="group py-2">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 text-lg font-medium text-ink-900 transition-colors hover:text-gold-dark [&::-webkit-details-marker]:hidden">
              {item.q}
              <svg class="h-5 w-5 shrink-0 text-gold-dark transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14"/></svg>
            </summary>
            <p class="pb-5 pr-8 leading-relaxed text-ink-700">{item.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-10 text-center reveal">
      <a href={path('contact', lang)} class="btn-outline">{t.common.contactUs}</a>
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
